{
  "name": "plex-poster-set-helper-2",
  "version": "2.2.4",
  "description": "Download and apply custom poster artwork from ThePosterDB and MediUX to your Plex Media Server",
  "author": "molexxxx",
  "license": "MIT",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .",
    "dev:web": "concurrently -k \"vite --mode web\" \"wait-on http://localhost:5173 && tsc -p tsconfig.server.json && PLEX_HELPER_WEB=1 node server/dist/server/index.js\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:web": "npm run build:renderer && npm run build:server",
    "build:renderer": "vite build",
    "build:renderer:web": "vite build --mode web",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:server": "tsc -p tsconfig.server.json",
    "start:web": "PLEX_HELPER_WEB=1 node server/dist/server/index.js",
    "icons": "node scripts/generate-icons.mjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run icons && npm run build && electron-builder --win",
    "dist:linux": "npm run icons && npm run build && electron-builder --linux",
    "lint": "eslint src electron server",
    "lint:fix": "eslint src electron server --fix",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "keywords": [
    "plex",
    "poster",
    "mediux",
    "posterdb",
    "electron"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/molexxxx/plex-poster-set-helper-2.git"
  },
  "overrides": {
    "form-data": "4.0.6",
    "undici": "7.28.0",
    "picomatch": "4.0.4"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "cheerio": "^1.2.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "fastify": "^5.9.0",
    "fuse.js": "^7.4.2",
    "node-cron": "^4.5.0",
    "p-limit": "^3.1.0",
    "playwright": "^1.61.1",
    "plex-oauth": "^2.2.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@types/node": "^26.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.14"
  }
}
