// tsconfig.electron.json

// This is the TypeScript configuration file for the Electron main process of the Plex Poster Set Helper project.

// It specifies the compiler options for targeting ES2020, using CommonJS modules, and includes settings for 
// strict type checking, skipping library checks, and resolving JSON modules.

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "electron/dist",
    "rootDir": "electron",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["electron"],
  "exclude": ["node_modules", "electron/dist"]
}
