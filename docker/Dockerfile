# syntax=docker/dockerfile:1
#
# Plex Poster Helper - browser-accessible GUI (KasmVNC).
#
#   http://  <host>:3000  - plain HTTP (no clipboard access in browser)
#   https:// <host>:3001  - HTTPS with a self-signed cert (enables clipboard)
#
# Clipboard paste from your local machine requires HTTPS because browsers block
# the Clipboard API on insecure origins. Use port 3001 and accept the self-signed
# certificate warning the first time. No extra setup needed - the cert is
# auto-generated by the base image on first start.
#
#   docker build -f docker/Dockerfile -t plex-poster-helper-2:gui .

# ----- Build stage -------------------------------------------------------------
FROM node:22-bookworm AS build
WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends unzip \
    && rm -rf /var/lib/apt/lists/*

# Skip Electron's own binary download (its postinstall is ESM-broken under Node
# 22); we fetch the matching binary explicitly below so it's baked into the image.
ENV ELECTRON_SKIP_BINARY_DOWNLOAD=1

# npm install (not ci): the committed lock is generated on Windows and lacks
# some Linux-only optional deps, which would make the strict `npm ci` fail.
COPY package*.json ./
RUN npm install --no-audit --no-fund

COPY . .
RUN npm run build   # vite build (renderer → src/dist) + tsc (electron → electron/dist)

# Drop dev dependencies for a leaner runtime copy.
RUN npm prune --omit=dev

# Electron is a devDependency (electron-builder requires that), but the container
# RUNS electron at runtime — so reinstall just electron after the prune and bake
# its Linux binary (the npm postinstall is skipped via ELECTRON_SKIP_BINARY_DOWNLOAD).
RUN set -eux; \
    npm install --no-save --no-audit --no-fund "electron@$(node -p "require('./package.json').devDependencies.electron")"; \
    EV="$(node -p "require('/build/node_modules/electron/package.json').version")"; \
    case "$(uname -m)" in x86_64) EA=x64;; aarch64|arm64) EA=arm64;; *) EA=x64;; esac; \
    curl -fsSL -o /tmp/electron.zip "https://github.com/electron/electron/releases/download/v${EV}/electron-v${EV}-linux-${EA}.zip"; \
    rm -rf node_modules/electron/dist && mkdir -p node_modules/electron/dist; \
    unzip -q /tmp/electron.zip -d node_modules/electron/dist; \
    chmod +x node_modules/electron/dist/electron; \
    printf 'electron' > node_modules/electron/path.txt; \
    rm /tmp/electron.zip

# ----- Runtime: KasmVNC desktop ------------------------------------------------
FROM lscr.io/linuxserver/baseimage-kasmvnc:debianbookworm

# Shared libraries Electron + Playwright Chromium need to run
RUN apt-get update && apt-get install -y --no-install-recommends \
      libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
      libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
      libgbm1 libpango-1.0-0 libcairo2 libasound2 libgtk-3-0 libxshmfence1 \
      libsecret-1-0 fonts-liberation \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Built app (renderer + compiled electron + pruned node_modules incl. electron)
COPY --from=build /build /app

# Autostart the GUI inside the VNC desktop
COPY docker/autostart /defaults/autostart
RUN chmod +x /defaults/autostart

# Make the browser actually ask for clipboard permission. The KasmVNC web client
# never triggers the Chrome/Edge permission prompt on its own (it only checks the
# state), leaving seamless clipboard dead until users dig into site settings.
# This script requests clipboard-read on the first click inside the client.
COPY docker/clipboard-prompt.js /usr/local/share/kasmvnc/www/clipboard-prompt.js
RUN printf '<script src="clipboard-prompt.js"></script>' \
      >> /usr/local/share/kasmvnc/www/index.html

# KasmVNC tuning: lossless encoding, native desktop resolution, max FPS, clipboard.
# The base image copies this .lsio template over the active kasmvnc.yaml on every
# start; we append only the sections we want to override.
RUN printf '\
\nencoding:\
\n  rect_encoding_mode:\
\n    min_quality: 10\
\n    max_quality: 10\
\n    preferred_encoding: Tight\
\n  jpeg_video_quality: 10\
\n  webp_image_quality: 10\
\n  max_frame_rate: 60\
\n  full_color: true\
\ndesktop:\
\n  allow_resize: true\
\n  force_desktop_size: false\
\nnetwork:\
\n  clipboard:\
\n    server_to_client:\
\n      enabled: true\
\n    client_to_server:\
\n      enabled: true\
\n' >> /usr/local/etc/kasmvnc/kasmvnc.yaml.lsio

# Persist config / logs / installed Chromium under the mounted /config volume,
# and behave correctly without a system tray.
ENV PLEX_HELPER_CONFIG_DIR=/config/app \
    PLEX_HELPER_NO_TRAY=1 \
    PLEX_HELPER_PROD=1 \
    PLEX_HELPER_DOCKER=1 \
    TITLE="Plex Poster Helper"

VOLUME /config
EXPOSE 3000 3001
